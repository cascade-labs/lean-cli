{
    "modules": [
        {
            "configurations": [
                {
                    "id": "hyperliquid-use-testnet",
                    "type": "input",
                    "input-method": "confirm",
                    "input-default": false,
                    "optional": true,
                    "help": "Whether to use the Hyperliquid testnet",
                    "prompt-info": "Use testnet?"
                },
                {
                    "id": "hyperliquid-aws-access-key-id",
                    "type": "input",
                    "input-method": "prompt",
                    "input-default": "",
                    "optional": true,
                    "help": "AWS access key ID for Hyperliquid S3 historical data (requester-pays). Leave empty to use REST API only.",
                    "prompt-info": "AWS Access Key ID (for S3 historical data, optional)"
                },
                {
                    "id": "hyperliquid-aws-secret-access-key",
                    "type": "input",
                    "input-method": "prompt-password",
                    "input-default": "",
                    "optional": true,
                    "help": "AWS secret access key for Hyperliquid S3 historical data.",
                    "prompt-info": "AWS Secret Access Key (for S3 historical data, optional)"
                },
                {
                    "filters": [
                        {
                            "condition": {
                                "dependent-config-id": "type",
                                "pattern": "data-downloader",
                                "type": "exact-match"
                            }
                        }
                    ],
                    "id": "data-provider",
                    "type": "info",
                    "value": "QuantConnect.Lean.Engine.DataFeeds.DownloaderDataProvider"
                },
                {
                    "filters": [
                        {
                            "condition": {
                                "dependent-config-id": "type",
                                "pattern": "data-downloader",
                                "type": "exact-match"
                            }
                        }
                    ],
                    "id": "data-downloader",
                    "type": "info",
                    "value": "QuantConnect.Lean.DataSource.HyperliquidData.HyperliquidDataDownloader"
                },
                {
                    "filters": [
                        {
                            "condition": {
                                "dependent-config-id": "type",
                                "pattern": "history-provider",
                                "type": "exact-match"
                            }
                        }
                    ],
                    "id": "history-provider",
                    "type": "info",
                    "value": "[\"QuantConnect.Lean.DataSource.HyperliquidData.HyperliquidHistoryProvider\"]"
                }
            ],
            "display-id": "Hyperliquid",
            "id": "HyperliquidDataDownloader",
            "platform": [
                "cli"
            ],
            "type": [
                "data-downloader",
                "history-provider"
            ]
        },
        {
            "configurations": [
                {
                    "help": "Your Fidelity username",
                    "id": "fidelity-user-name",
                    "input-method": "prompt",
                    "prompt-info": "Fidelity username",
                    "type": "input"
                },
                {
                    "help": "Your Fidelity password",
                    "id": "fidelity-password",
                    "input-method": "prompt-password",
                    "prompt-info": "Fidelity password",
                    "type": "input"
                },
                {
                    "help": "Your Fidelity TOTP secret for authenticator-based 2FA",
                    "id": "fidelity-totp-secret",
                    "input-default": "",
                    "input-method": "prompt-password",
                    "optional": true,
                    "prompt-info": "Fidelity TOTP secret",
                    "type": "input"
                },
                {
                    "help": "Your Fidelity account number to trade in",
                    "id": "fidelity-account",
                    "input-method": "prompt",
                    "prompt-info": "Fidelity account number",
                    "type": "input"
                },
                {
                    "filters": [
                        {
                            "condition": {
                                "dependent-config-id": "type",
                                "pattern": "brokerage",
                                "type": "exact-match"
                            }
                        }
                    ],
                    "id": "live-mode-brokerage",
                    "type": "info",
                    "value": "FidelityBrokerage"
                }
            ],
            "display-id": "Fidelity",
            "id": "FidelityBrokerage",
            "installs": false,
            "live-cash-balance-state": "not-supported",
            "live-holdings-state": "not-supported",
            "platform": [
                "cli"
            ],
            "type": [
                "brokerage"
            ]
        }
    ]
}
